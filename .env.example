PORT=3000
NODE_ENV=development

# Allowed origins for browser clients. Separate multiple origins with comma.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Request body size limit for JSON endpoints.
API_BODY_LIMIT=10mb

HASURA_URL=https://your-project.hasura.ap-southeast-1.nhost.run/v1/graphql
HASURA_ADMIN_SECRET=your_hasura_admin_secret

NHOST_AUTH_URL=https://your-project.auth.ap-southeast-1.nhost.run/v1
NHOST_STORAGE_URL=https://your-project.storage.ap-southeast-1.nhost.run/v1

DEFAULT_STORAGE_BUCKET=default
MAX_UPLOAD_SIZE_MB=25

# Rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=25
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=500

# Import hardening
IMPORT_MAX_ROWS=2000
IMPORT_ALLOWED_ENTITIES_ADMIN=devices,pops,projects,regions
IMPORT_ALLOWED_ENTITIES_USER_ALL_REGION=devices,pops,projects
IMPORT_ALLOWED_ENTITIES_USER_REGION=devices,pops

# Used only for initial admin bootstrap. Rotate after first use.
BOOTSTRAP_ADMIN_SECRET=change_this_bootstrap_secret

# Optional smoke test values for CI/local scripts
SMOKE_BASE_URL=http://127.0.0.1:3000
SMOKE_ADMIN_EMAIL=admin@syntrix.local
SMOKE_ADMIN_PASSWORD=AdminKuat123!
